{
  "name": "matrix-worker",
  "version": "0.1.0",
  "description": "Matrix homeserver running on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute tuwunel-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute tuwunel-db --local --file=./migrations/schema.sql",
    "dev:local": "LIBSQL_URL=http://localhost:8080 SERVER_NAME=localhost:8787 bun run src/preload.ts",
    "start": "bun run src/preload.ts",
    "db:migrate:libsql": "bun run scripts/migrate-libsql.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "self-hosted": "bash scripts/self-hosted.sh"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@libsql/client": "^0.17.0",
    "hono": "^4.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.61.0"
  }
}