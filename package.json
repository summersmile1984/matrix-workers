{
  "name": "matrix-worker",
  "version": "0.1.0",
  "description": "Matrix homeserver running on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=./../.certs/caddy-root-ca.crt LIBSQL_URL=http://localhost:8080 bun run src/preload.ts",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute tuwunel-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute tuwunel-db --local --file=./migrations/schema.sql",
    "start": "bun run src/preload.ts",
    "db:migrate:libsql": "bun run scripts/migrate-libsql.ts",
    "db:push": "bun run scripts/migrate-libsql.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "self-hosted": "bash scripts/self-hosted.sh --"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@libsql/client": "^0.17.0",
    "@mastra/core": "^1.8.0",
    "@mastra/libsql": "^1.6.2",
    "hono": "^4.6.0",
    "matrix-js-sdk": "^41.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.61.0"
  }
}